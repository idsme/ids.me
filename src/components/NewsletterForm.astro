---
export interface Props {
  variant?: "default" | "compact";
}

const { variant = "default" } = Astro.props;
---

<div class={variant === 'default' ? 'newsletter-box bg-gray-50 dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700 rounded-lg p-6 my-8' : 'newsletter-compact mt-6'}>
  {variant === 'default' && (
    <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
      Want to stay in touch? Connect with me on social media or drop me an email.
    </p>
  )}
  
  <div class="flex flex-col sm:flex-row gap-3 items-center justify-center">
    <a
      href="https://github.com/idsme"
      target="_blank"
      rel="noopener noreferrer"
      class="px-6 py-2 bg-gray-800 dark:bg-gray-700 text-white rounded-md hover:bg-gray-700 dark:hover:bg-gray-600 transition-colors font-medium whitespace-nowrap"
    >
      GitHub
    </a>
    <a
      href="https://www.linkedin.com/in/idsachterhof/"
      target="_blank"
      rel="noopener noreferrer"
      class="px-6 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-500 transition-colors font-medium whitespace-nowrap"
    >
      LinkedIn
    </a>
    <a
      href="mailto:idsmedev@gmail.com"
      class="px-6 py-2 bg-accent text-white rounded-md hover:bg-accent/90 transition-colors font-medium whitespace-nowrap"
    >
      Email Me
    </a>
  </div>
</div>

<style>
  @media (max-width: 640px) {
    .newsletter-box {
      margin-left: -1rem;
      margin-right: -1rem;
      border-radius: 0;
    }
  }
</style>

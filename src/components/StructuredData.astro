---
export interface Props {
  type: "BlogPosting" | "Person" | "WebSite";
  data: any;
}

const { type, data } = Astro.props;

let structuredData = {};

if (type === "BlogPosting") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: data.title,
    description: data.description,
    author: {
      "@type": "Person",
      name: data.author || "Ids Achterhof",
      url: "https://idsme.dev/about",
    },
    datePublished: data.pubDatetime.toISOString(),
    dateModified: data.modDatetime?.toISOString() || data.pubDatetime.toISOString(),
    publisher: {
      "@type": "Person",
      name: "Ids Achterhof",
      logo: {
        "@type": "ImageObject",
        url: "https://pbs.twimg.com/profile_images/458998633753350144/jZd8j_xf.jpeg",
      },
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": data.url,
    },
    image: data.ogImage || "https://cdn.prod.website-files.com/61845f7929f5aa517ebab941/6476e0de1571149966c20da2_Digital%20Identity-What%20It%20Is%20and%20Why%20It%20Matters%20in%20Today%27s%20World.jpg",
    articleSection: data.tags?.[0] || "Technology",
    keywords: data.tags?.join(", ") || "",
    wordCount: data.wordCount,
    timeRequired: data.readingTime,
  };
} else if (type === "Person") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Ids Achterhof",
    url: "https://odusports.com/imgproxy/7vn6W63iC66ByVyD20aax8QHZgkh5J8s0DQ3SURh75E/rs:fit:1980:0:0:0/g:ce:0:0/q:90/aHR0cHM6Ly9zdG9yYWdlLmdvb2dsZWFwaXMuY29tL29kdS1wcm9kLzIwMjQvMDEvMjIveUpwNHhsV0tTVkhzaFg4MVdaOUNUUmJMcXk0N0VxcUxHalVMbW1rby5qcGc.jpg",
    image: "https://media.licdn.com/dms/image/v2/D4E03AQHF6WPcjXor5w/profile-displayphoto-scale_200_200/B4EZxqgE3lJYAY-/0/1771313324943?e=2147483647&v=beta&t=8VTlwZ3iCzPmkzLneLSUR705a_hfXaz7Z4rGuVuSgfA",
    sameAs: [
      "https://github.com/idsme",
      "https://x.com/idsmedev",
      "https://www.linkedin.com/in/idsachterhof/",
    ],
    jobTitle: "Enterprise Architect",
    description:
      "Enterprise Architect building scalable digital solutions. Bridging technology and business with pragmatic, innovative approaches.",
  };
} else if (type === "WebSite") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Ids Achterhof",
    url: "https://idsme.dev",
    description:
      "Enterprise Architect building scalable digital solutions. Bridging technology and business with pragmatic, innovative approaches.",
    author: {
      "@type": "Person",
      name: "Ids Achterhof",
    },
    potentialAction: {
      "@type": "SearchAction",
      target: "https://idsme.dev/search?q={search_term_string}",
      "query-input": "required name=search_term_string",
    },
  };
}
---

<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
